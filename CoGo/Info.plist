<?xml version="1.0" encoding="UTF-8"?> <!-- 플리스트 파일의 XML 버전을 선언합니다. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd"> <!-- Apple 표준 plist 문서 형식을 선언합니다. -->
<plist version="1.0"> <!-- 이 문서가 plist 1.0 형식임을 나타냅니다. -->
<dict> <!-- 앱 권한과 설정 키를 담는 최상위 딕셔너리를 엽니다. -->
    <key>NSBonjourServices</key> <!-- 앱이 광고하고 탐색할 Bonjour 서비스 목록 키입니다. -->
    <array> <!-- 여러 Bonjour 서비스 타입을 담을 수 있는 배열을 엽니다. -->
        <string>_cogo-nearby._tcp</string> <!-- MultipeerConnectivity가 내부적으로 사용할 Bonjour 서비스 타입을 선언합니다. -->
    </array> <!-- Bonjour 서비스 배열을 닫습니다. -->
    <key>NSCameraUsageDescription</key> <!-- 카메라 접근 권한 요청 시 보여줄 설명 문자열 키입니다. -->
    <string>카메라 화면 위에 주변 CoGo 사용자를 표시하기 위해 카메라를 사용합니다.</string> <!-- 카메라 권한이 필요한 이유를 사용자에게 설명합니다. -->
    <key>NSLocalNetworkUsageDescription</key> <!-- 로컬 네트워크 접근 권한 요청 시 보여줄 설명 문자열 키입니다. -->
    <string>내 주변의 CoGo 사용자를 찾고 표시하기 위해 로컬 네트워크를 사용합니다.</string> <!-- 주변 기기 탐색 목적을 사용자에게 설명합니다. -->
    <key>NSPhotoLibraryUsageDescription</key> <!-- 사진 접근 권한 요청 시 보여줄 설명 문자열 키입니다. -->
    <string>프로필 사진을 등록하기 위해 사진 보관함에 접근합니다.</string> <!-- 프로필 사진 선택 목적을 사용자에게 설명합니다. -->
</dict> <!-- 최상위 설정 딕셔너리를 닫습니다. -->
</plist> <!-- plist 문서를 닫습니다. -->
